        }
      },
      {
        "topic": "/roboclaw/action",
        "payload": {
          "event": "step_failed",
          "skill": "pick_and_place",
          "step": "place_object",
          "tool": "simulator"
        }
      },
      {
        "topic": "/roboclaw/state",
        "payload": {
          "backend": "gazebo",
          "last_action": "place",
          "last_pose": "bin_a",
          "held_object": "red_cube",
          "active_skill": "pick_and_place",
          "completed": false,
          "failed_step": "place_object"
        }
      },
      {
        "topic": "/roboclaw/action",
        "payload": {
          "event": "execution_replan_requested",
          "skill": "pick_and_place",
