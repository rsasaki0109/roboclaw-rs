          "data": {
            "resume_from_step": "place_object"
          }
        }
      },
      {
        "topic": "/cmd_vel",
        "payload": {
          "linear": 0.0,
          "angular": 0.0,
          "source": "gazebo"
        }
      }
    ],
    "expected_active_skill": "pick_and_place",
    "expected_last_pose": "bin_a",
    "expected_held_object": "red_cube",
    "expected_failed_step": "place_object",
    "expected_resume_step": "place_object",
    "expected_motion_state": "idle",
    "why": "A placement failure should preserve the held-object fact together with the placement checkpoint."
  },
  {
    "id": "stale_state_then_wave",
    "events": [
      {
        "topic": "/roboclaw/state",
        "payload": {
          "backend": "gazebo",
